  "info": {
    "title": "TianguisWatt API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/accepted-actions": {
      "get": {
        "operationId": "accepted_actions_api_accepted_actions_get",
        "parameters": [
          {
            "description": "Number of recent actions.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 8,
              "description": "Number of recent actions.",
              "maximum": 50,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AcceptedAction"
                  },
                  "title": "Response Accepted Actions Api Accepted Actions Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Accepted Actions"
      }
    },
    "/api/bid-stack": {
      "get": {
        "operationId": "bid_stack_api_bid_stack_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BidStack"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Bid Stack"
      }
    },
