    "/api/timeseries": {
      "get": {
        "operationId": "timeseries_api_timeseries_get",
        "parameters": [
          {
            "in": "query",
            "name": "metric",
            "required": true,
            "schema": {
              "enum": [
                "demand",
                "generation",
                "carbon",
                "price"
              ],
              "title": "Metric",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "granularity",
            "required": false,
            "schema": {
              "default": "hour",
              "enum": [
                "sp",
                "hour",
                "day"
              ],
              "title": "Granularity",
              "type": "string"
            }
          },
          {
            "description": "Window in hours (max 30 days).",
            "in": "query",
            "name": "hours",
            "required": false,
            "schema": {
              "default": 24,
              "description": "Window in hours (max 30 days).",
              "maximum": 720,
              "minimum": 1,
              "title": "Hours",
              "type": "integer"
            }
          }
        ],
