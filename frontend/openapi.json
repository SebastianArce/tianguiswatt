        "operationId": "carbon_api_carbon_get",
        "parameters": [
          {
            "description": "History window in hours.",
            "in": "query",
            "name": "hours",
            "required": false,
            "schema": {
              "default": 6,
              "description": "History window in hours.",
              "maximum": 168,
              "minimum": 1,
              "title": "Hours",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CarbonPoint"
                  },
                  "title": "Response Carbon Api Carbon Get",
                  "type": "array"
